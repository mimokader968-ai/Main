{
  "name": "autoflow-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "AutoFlow - Workflow Automation Platform",
  "engines": {
    "node": ">=22.16",
    "pnpm": ">=10.22.0"
  },
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel --env-mode=loose",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "turbo run format",
    "clean": "turbo run clean && rm -rf node_modules",
    "start": "node packages/cli/bin/autoflow",
    "docker:build": "docker build -t autoflow .",
    "docker:run": "docker-compose up"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "turbo": "^1.10.0"
  }
}
